# Normalize line endings to LF on commit across all OS
* text=auto eol=lf

# Java and config files — always LF
*.java text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.md text eol=lf

# Windows scripts — keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binaries — no line ending conversion
*.jar binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
