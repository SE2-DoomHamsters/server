root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Google Java Style: 2-space indentation, spaces only
[*.java]
indent_style = space
indent_size = 2

[*.{xml,yml,yaml}]
indent_style = space
indent_size = 2

[*.properties]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false
